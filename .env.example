# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID (only this user can message the bot)
# Get yours by messaging @userinfobot
TELEGRAM_ALLOWED_USER_ID=

# Claude CLI binary (full path)
CLAUDE_BIN=/home/tdporter/.local/bin/claude

# Default working directory for Claude sessions
DEFAULT_CWD=/home/tdporter/Documents/Obsidian

# Where to stash session state
STATE_DIR=/home/tdporter/Documents/Programming/claude-telegram/.data

# Claude model alias for this bot (sonnet | haiku | opus, or full model ID).
# Sonnet 4.6 + low effort is the chat-from-phone sweet spot.
CLAUDE_MODEL=sonnet

# Thinking budget: low | medium | high | xhigh | max.
# "low" keeps replies snappy for capture-style messages.
CLAUDE_EFFORT=low
